generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  lecturer
  student
}

enum StudentStatus {
  active
  inactive
  graduated
  expelled
}

enum Gender {
  male
  female
}

enum AttendanceStatus {
  present
  absent
}

enum EnrollmentStatus {
  REGISTERED
  DROPPED
  WITHDRAWN
  COMPLETED
  WAITLISTED
}

model User {
  id               String    @id
  name             String
  email            String    @unique
  password         String
  role             Role
  avatar           String?
  emailVerified    Boolean   @default(false) @map("emailVerified")
  resetToken        String?   @unique @map("resetToken")
  resetTokenExpires DateTime? @map("resetTokenExpires")

  accountRequests AccountRequest[] @relation("schoolEmail")
  @@map("users")
}

model Student {
  id             String        @id
  firstName      String        @map("firstName")
  lastName       String        @map("lastName")
  email          String        @unique
  dateOfBirth    String?       @map("dateOfBirth")
  gender         Gender?
  year           String
  department     String?
  facultyId      String?       @map("facultyId")
  enrollmentDate String?       @map("enrollmentDate")
  status         StudentStatus @default(active)
  studentNumber  String?       @unique @map("studentNumber")
  maxCredits     Int?          @map("maxCredits")

  attendance          Attendance[]
  grades              Grade[]
  submissions         AssignmentSubmission[]
  claims              Claim[]
  invoices            Invoice[]
  examResults         ExamResult[]
  enrollments         Enrollment[]
  waitlistEntries     WaitlistEntry[]
  faculty             Faculty?   @relation(fields: [facultyId], references: [id])
  @@map("students")
}

model Lecturer {
  id                    String   @id
  firstName             String   @map("firstName")
  lastName              String   @map("lastName")
  email                 String   @unique
  department            String?
  assignedCourses       Json     @default("[]") @map("assignedCourses")
  qualification         String?
  joinDate              String?  @map("joinDate")
  invitationToken       String?  @unique @map("invitationToken")
  invitationTokenExpires DateTime? @map("invitationTokenExpires")
  invitationAcceptedAt  DateTime? @map("invitationAcceptedAt")

  courses Course[]
  groups   Group[]
  grades   Grade[]
  exams    Exam[]
  @@map("lecturers")
}

model Department {
  id              String  @id
  name            String
  code            String?
  headLecturerId  String? @map("headLecturerId")
  description     String?

  faculties Faculty[]
  @@map("departments")
}

model Faculty {
  id           String @id
  name         String
  code         String?
  departmentId String @map("departmentId")
  description  String?

  department Department @relation(fields: [departmentId], references: [id])
  students   Student[]
  courses    Course[]
  @@map("faculties")
}

model Semester {
  id                    String  @id
  name                  String
  year                  String?
  startDate             String? @map("startDate")
  endDate               String? @map("endDate")
  isActive              Int     @default(0) @map("isActive")
  registrationOpenDate  String? @map("registrationOpenDate")
  registrationCloseDate String? @map("registrationCloseDate")
  dropDeadline          String? @map("dropDeadline")
  withdrawDeadline      String? @map("withdrawDeadline")
  maxCreditsPerStudent  Int     @default(21) @map("maxCreditsPerStudent")

  groups      Group[]
  enrollments Enrollment[]
  waitlistEntries WaitlistEntry[]
  @@map("semesters")
}

model Room {
  id          String   @id
  name        String
  code        String?  @unique
  capacity    Int      @default(0)
  building    String?
  description String?

  courses Course[]
  groups  Group[]
  exams   Exam[]

  @@map("rooms")
}

model Group {
  id                  String  @id
  name                String
  courseId            String  @map("courseId")
  semesterId          String? @map("semesterId")
  lecturerId          String? @map("lecturerId")
  roomId              String? @map("roomId")
  capacity            Int     @default(30)
  schedule            Json    @default("[]")
  enrolledStudentIds  Json    @default("[]") @map("enrolledStudentIds")

  course   Course    @relation(fields: [courseId], references: [id])
  lecturer Lecturer? @relation(fields: [lecturerId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  semester Semester? @relation(fields: [semesterId], references: [id])
  grades   Grade[]
  exams    Exam[]
  enrollments      Enrollment[]
  waitlistEntries  WaitlistEntry[]

  @@index([courseId])
  @@index([lecturerId])
  @@map("groups")
}

model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  groupId    String
  courseId   String
  semesterId String
  status     EnrollmentStatus @default(REGISTERED)
  enrolledAt DateTime         @default(now())
  droppedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  student  Student  @relation(fields: [studentId], references: [id])
  group    Group    @relation(fields: [groupId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  @@unique([studentId, groupId, semesterId])
  @@index([studentId])
  @@index([groupId])
  @@index([courseId])
  @@index([semesterId])
  @@index([status])
  @@map("enrollments")
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  studentId  String
  groupId    String
  courseId   String
  semesterId String
  position   Int
  createdAt  DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id])
  group    Group    @relation(fields: [groupId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  @@unique([groupId, position])
  @@index([studentId])
  @@index([groupId])
  @@index([courseId])
  @@map("waitlist_entries")
}

model Course {
  id                String  @id
  name              String
  year              String?
  department        String?
  facultyId         String? @map("facultyId")
  lecturerId        String? @map("lecturerId")
  semesterId        String? @map("semesterId")
  credits           Int     @default(3)
  roomId            String? @map("roomId")
  gradingComponents Json    @default("[]") @map("gradingComponents")
  maxStudents       Int?    @map("maxStudents")

  lecturer   Lecturer?    @relation(fields: [lecturerId], references: [id])
  faculty    Faculty?     @relation(fields: [facultyId], references: [id])
  room       Room?        @relation(fields: [roomId], references: [id])
  groups     Group[]
  attendance Attendance[]
  grades     Grade[]
  assignments Assignment[]
  materials   CourseMaterial[]
  exams      Exam[]
  enrollments         Enrollment[]
  waitlistEntries     WaitlistEntry[]
  @@map("courses")
}

model Attendance {
  id        String           @id
  courseId   String?          @map("courseId")
  studentId  String?          @map("studentId")
  date      String?
  status    AttendanceStatus?
  markedBy  String?          @map("markedBy")

  course  Course?  @relation(fields: [courseId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([courseId], name: "idx_attendance_course")
  @@index([studentId], name: "idx_attendance_student")
  @@map("attendance")
}

model Grade {
  id              String    @id
  studentId       String?   @map("studentId")
  courseId        String?   @map("courseId")
  groupId         String?   @map("groupId")
  lecturerId      String?   @map("lecturerId")
  semester        String?
  score           Float     @default(0)
  maxScore        Float     @default(100) @map("maxScore")
  grade           String?
  comments        String?
  componentScores Json      @default("{}") @map("componentScores")
  status          String    @default("draft")
  submittedAt     DateTime? @map("submittedAt")
  approvedAt      DateTime? @map("approvedAt")
  approvedById    String?   @map("approvedById")
  rejectedAt      DateTime? @map("rejectedAt")
  rejectedById    String?   @map("rejectedById")
  rejectionNote   String?   @map("rejectionNote")

  course   Course?   @relation(fields: [courseId], references: [id])
  student  Student?  @relation(fields: [studentId], references: [id])
  group    Group?    @relation(fields: [groupId], references: [id])
  lecturer Lecturer? @relation(fields: [lecturerId], references: [id])

  @@index([studentId], name: "idx_grades_student")
  @@index([courseId], name: "idx_grades_course")
  @@index([groupId], name: "idx_grades_group")
  @@index([lecturerId], name: "idx_grades_lecturer")
  @@index([status], name: "idx_grades_status")
  @@map("grades")
}

model Announcement {
  id          String   @id
  title       String
  body        String?
  targetRoles Json     @default("[]") @map("targetRoles")
  createdBy   String?  @map("createdBy")
  createdAt   DateTime @default(now()) @map("createdAt")
  priority    String   @default("normal")

  @@map("announcements")
}

model AccountRequest {
  id            String    @id
  name          String?
  email         String?
  studentId     String?   @map("studentId")
  classOrSubject String?  @map("classOrSubject")
  message       String?
  status        String    @default("pending")
  flagged       Boolean   @default(false)
  schoolEmail   String?   @map("schoolEmail")
  password      String?
  createdAt     DateTime  @default(now()) @map("createdAt")
  approvedAt    DateTime? @map("approvedAt")

  user User? @relation("schoolEmail", fields: [schoolEmail], references: [email])
  @@map("account_requests")
}

model AuditLog {
  id             String   @id
  action         String?
  performedBy    String?  @map("performedBy")
  performedById  String?  @map("performedById")
  targetType     String?  @map("targetType")
  targetId       String?  @map("targetId")
  details        String?
  timestamp      DateTime @default(now()) @map("timestamp")

  @@index([timestamp(sort: Desc)], name: "idx_audit_logs_timestamp")
  @@map("audit_logs")
}

enum SubmissionStatus {
  pending
  submitted
  graded
  overdue
}

enum EventType {
  exam
  deadline
  holiday
  event
}

enum MaterialType {
  slide
  syllabus
  reading
}

enum ClaimStatus {
  pending
  approved
  rejected
}

enum InvoiceStatus {
  pending
  paid
  overdue
  cancelled
}

enum PaymentMethod {
  bank_transfer
  mobile_money
  credit_card
  cash
}

model Assignment {
  id          String   @id
  courseId    String?  @map("courseId")
  courseName  String?  @map("courseName")
  title       String
  description String?
  dueDate     String?  @map("dueDate")
  maxScore    Float    @default(100) @map("maxScore")
  attachments Json     @default("[]")
  createdBy   String?  @map("createdBy")
  createdAt   DateTime @default(now()) @map("createdAt")

  course Course? @relation(fields: [courseId], references: [id])
  submissions AssignmentSubmission[]

  @@index([courseId], name: "idx_assignments_course")
  @@map("assignments")
}

model AssignmentSubmission {
  id          String           @id
  assignmentId String?          @map("assignmentId")
  studentId   String?          @map("studentId")
  submittedAt DateTime?        @map("submittedAt")
  fileUrl     String?          @map("fileUrl")
  content     String?
  status      SubmissionStatus @default(submitted)
  score       Float?
  feedback    String?
  gradedAt    DateTime?        @map("gradedAt")

  assignment Assignment? @relation(fields: [assignmentId], references: [id])
  student    Student?    @relation(fields: [studentId], references: [id])

  @@index([assignmentId], name: "idx_submissions_assignment")
  @@index([studentId], name: "idx_submissions_student")
  @@map("assignment_submissions")
}

model CalendarEvent {
  id          String    @id
  title       String
  description String?
  type        EventType
  date        String?
  time        String?
  endTime     String?   @map("endTime")
  courseId    String?   @map("courseId")
  courseName  String?   @map("courseName")
  targetRoles Json      @default("[]") @map("targetRoles")
  createdBy   String?   @map("createdBy")
  createdAt   DateTime  @default(now()) @map("createdAt")

  @@index([type], name: "idx_events_type")
  @@index([date], name: "idx_events_date")
  @@map("calendar_events")
}

model CourseMaterial {
  id          String       @id
  title       String
  type        MaterialType
  courseId    String?      @map("courseId")
  courseName  String?      @map("courseName")
  fileName    String?      @map("fileName")
  description String?
  uploadedBy  String?      @map("uploadedBy")
  uploadedAt  DateTime     @default(now()) @map("uploadedAt")

  course Course? @relation(fields: [courseId], references: [id])
  @@index([courseId], name: "idx_materials_course")
  @@index([type], name: "idx_materials_type")
  @@map("course_materials")
}

model Claim {
  id            String      @id
  gradeId       String?     @map("gradeId")
  studentId     String?     @map("studentId")
  courseId      String?     @map("courseId")
  subject       String?
  semester      String?
  claimedGrade  String?     @map("claimedGrade")
  reason        String?
  status        ClaimStatus @default(pending)
  createdAt     DateTime    @default(now()) @map("createdAt")
  resolvedAt    DateTime?   @map("resolvedAt")
  resolvedBy    String?     @map("resolvedBy")
  resolutionNote String?    @map("resolutionNote")

  student Student? @relation(fields: [studentId], references: [id])
  @@index([studentId], name: "idx_claims_student")
  @@index([courseId], name: "idx_claims_course")
  @@index([status], name: "idx_claims_status")
  @@map("grade_appeals")
}

model Invoice {
  id           String         @id
  studentId    String?        @map("studentId")
  studentName  String?        @map("studentName")
  totalAmount  Float          @map("totalAmount")
  dueDate      String?        @map("dueDate")
  status       InvoiceStatus  @default(pending)
  semester     String?
  academicYear String?        @map("academicYear")
  createdAt    DateTime       @default(now()) @map("createdAt")

  student Student? @relation(fields: [studentId], references: [id])
  items   InvoiceItem[]
  payments Payment[]

  @@index([studentId], name: "idx_invoices_student")
  @@index([status], name: "idx_invoices_status")
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id
  invoiceId   String? @map("invoiceId")
  description String?
  amount      Float

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId], name: "idx_invoice_items_invoice")
  @@map("invoice_items")
}

model Payment {
  id         String        @id
  invoiceId  String?       @map("invoiceId")
  amount     Float
  method     PaymentMethod
  reference  String?
  paidAt     DateTime?     @map("paidAt")
  receivedBy String?       @map("receivedBy")

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId], name: "idx_payments_invoice")
  @@map("payments")
}

model Exam {
  id               String   @id
  title            String
  courseId         String   @map("courseId")
  groupId          String?  @map("groupId")
  lecturerId       String?  @map("lecturerId")
  roomId           String?  @map("roomId")
  date             String?
  startTime        String?  @map("startTime")
  endTime          String?  @map("endTime")
  maxScore         Float    @default(100) @map("maxScore")
  type             String   @default("exam")
  status           String   @default("scheduled")
  gradingComponent String?  @map("gradingComponent")
  createdAt        DateTime @default(now()) @map("createdAt")

  course   Course    @relation(fields: [courseId], references: [id])
  group    Group?    @relation(fields: [groupId], references: [id])
  lecturer Lecturer? @relation(fields: [lecturerId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  results  ExamResult[]

  @@index([courseId], name: "idx_exams_course")
  @@index([groupId], name: "idx_exams_group")
  @@index([lecturerId], name: "idx_exams_lecturer")
  @@index([status], name: "idx_exams_status")
  @@map("exams")
}

model ExamResult {
  id            String    @id
  examId        String    @map("examId")
  studentId     String    @map("studentId")
  score         Float     @default(0)
  status        String    @default("draft")
  gradedById    String?   @map("gradedById")
  gradedAt      DateTime? @map("gradedAt")
  approvedAt    DateTime? @map("approvedAt")
  rejectedAt    DateTime? @map("rejectedAt")
  rejectionNote String?   @map("rejectionNote")
  comments      String?

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([examId], name: "idx_exam_results_exam")
  @@index([studentId], name: "idx_exam_results_student")
  @@map("exam_results")
}

model Message {
  id            String   @id
  senderId      String?  @map("senderId")
  senderName    String?  @map("senderName")
  senderRole    String?  @map("senderRole")
  recipientId   String?  @map("recipientId")
  recipientName String?  @map("recipientName")
  recipientRole String?  @map("recipientRole")
  subject       String?
  body          String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("createdAt")
  parentId      String?  @map("parentId")

  parent   Message?  @relation("MessageThread", fields: [parentId], references: [id])
  replies  Message[] @relation("MessageThread")

  @@index([senderId], name: "idx_messages_sender")
  @@index([recipientId], name: "idx_messages_recipient")
  @@index([parentId], name: "idx_messages_parent")
  @@map("messages")
}
